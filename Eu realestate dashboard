<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>EU Real Estate — Market Intelligence Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0D1117;--panel:#161B22;--card:#1C2128;--border:#30363D;
  --text:#E6EDF3;--muted:#8B949E;--faint:#21262D;
  --blue:#58A6FF;--gold:#D29922;--green:#3FB950;--red:#F85149;
  --purple:#BC8CFF;--cyan:#39C5CF;--orange:#F0883E;
  --r:10px;--shadow:0 4px 20px rgba(0,0,0,.5);
}
body{font-family:-apple-system,'SF Pro Display','Segoe UI',system-ui,sans-serif;
     background:var(--bg);color:var(--text);font-size:13px;min-height:100vh}
#app{max-width:1460px;margin:0 auto;padding:18px 20px 32px}

/* ── HEADER ── */
.hdr{display:flex;align-items:flex-end;justify-content:space-between;
     margin-bottom:16px;flex-wrap:wrap;gap:10px;
     border-bottom:1px solid var(--border);padding-bottom:16px}
.logo{display:flex;align-items:center;gap:12px}
.logo-icon{width:36px;height:36px;border-radius:8px;
           background:linear-gradient(135deg,var(--blue),var(--purple));
           display:flex;align-items:center;justify-content:center;font-size:18px}
.logo h1{font-size:17px;font-weight:700;letter-spacing:-.3px}
.logo p{font-size:11px;color:var(--muted);margin-top:2px;font-family:monospace}
.hdr-badges{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
.hbadge{font-size:10px;padding:3px 10px;border-radius:20px;font-weight:600;
        letter-spacing:.06em;text-transform:uppercase;font-family:monospace;border:1px solid}
.hb-b{color:var(--blue);border-color:var(--blue);background:rgba(88,166,255,.1)}
.hb-g{color:var(--gold);border-color:var(--gold);background:rgba(210,153,34,.1)}
.hb-gr{color:var(--green);border-color:var(--green);background:rgba(63,185,80,.1)}

/* ── FILTERS ── */
.filters{background:var(--panel);border:1px solid var(--border);border-radius:var(--r);
         padding:14px 18px;margin-bottom:14px;display:flex;flex-wrap:wrap;
         gap:14px;align-items:flex-end}
.fg{display:flex;flex-direction:column;gap:4px;min-width:120px;flex:1;max-width:200px}
.flbl{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;
      letter-spacing:.08em;font-family:monospace}
.fg select,.fg input[type=range]{width:100%;background:var(--card);border:1px solid var(--border);
  border-radius:6px;color:var(--text);padding:6px 10px;font-size:12px;cursor:pointer}
.fg select:focus{outline:none;border-color:var(--blue)}
.fg input[type=range]{padding:4px 0;accent-color:var(--blue)}
.fval{font-family:monospace;font-weight:700;color:var(--blue);font-size:12px;padding:2px 0}
.freset{background:rgba(248,81,73,.1);border:1px solid var(--red);color:var(--red);
        border-radius:6px;padding:6px 14px;cursor:pointer;font-size:11px;
        font-weight:700;text-transform:uppercase;letter-spacing:.05em;
        white-space:nowrap;align-self:flex-end;font-family:monospace}
.freset:hover{background:rgba(248,81,73,.2)}

/* ── KPIs ── */
.kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:12px}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:var(--r);
     padding:14px 16px;position:relative;overflow:hidden;transition:border-color .2s}
.kpi:hover{border-color:var(--blue)}
.kpi-stripe{position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:var(--r) 0 0 var(--r)}
.kpi-lbl{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;
         letter-spacing:.07em;font-family:monospace;margin-bottom:8px}
.kpi-val{font-size:22px;font-weight:800;font-family:monospace;letter-spacing:-1px;color:var(--text)}
.kpi-sub{font-size:11px;color:var(--muted);margin-top:4px}
.kpi-delta{display:inline-flex;align-items:center;gap:3px;font-size:11px;
           font-weight:700;margin-top:6px;font-family:monospace;padding:2px 6px;
           border-radius:4px}
.kpi-up{background:rgba(63,185,80,.15);color:var(--green)}
.kpi-dn{background:rgba(248,81,73,.15);color:var(--red)}

/* ── GRID ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px}
.g23{display:grid;grid-template-columns:2fr 3fr;gap:10px;margin-bottom:10px}
.g32{display:grid;grid-template-columns:3fr 2fr;gap:10px;margin-bottom:10px}

/* ── CARDS ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:16px}
.card-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px}
.card-title{font-size:12px;font-weight:700;color:var(--text);letter-spacing:-.1px}
.card-sub{font-size:11px;color:var(--muted);margin-top:2px}
.ctag{font-size:9px;padding:2px 7px;border-radius:4px;font-weight:700;
      letter-spacing:.06em;text-transform:uppercase;white-space:nowrap;font-family:monospace;border:1px solid}
.ctag-b{color:var(--blue);border-color:rgba(88,166,255,.4);background:rgba(88,166,255,.08)}
.ctag-g{color:var(--gold);border-color:rgba(210,153,34,.4);background:rgba(210,153,34,.08)}
.ctag-gr{color:var(--green);border-color:rgba(63,185,80,.4);background:rgba(63,185,80,.08)}
.ctag-r{color:var(--red);border-color:rgba(248,81,73,.4);background:rgba(248,81,73,.08)}
.ctag-p{color:var(--purple);border-color:rgba(188,140,255,.4);background:rgba(188,140,255,.08)}

/* ── CHARTS ── */
.cw{position:relative}

/* ── INSIGHT BOX ── */
.insight{background:rgba(88,166,255,.06);border-left:2px solid var(--blue);
         border-radius:0 6px 6px 0;padding:8px 11px;margin-top:10px;
         font-size:11px;color:var(--muted);line-height:1.6;font-style:italic}
.insight strong{color:var(--blue);font-style:normal}

/* ── RANKING TABLE ── */
.rtbl{width:100%;border-collapse:collapse;font-size:12px}
.rtbl th{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);
         font-weight:700;padding:0 8px 8px;text-align:left;border-bottom:1px solid var(--border);
         font-family:monospace}
.rtbl td{padding:8px 8px;border-bottom:1px solid rgba(48,54,61,.6);vertical-align:middle}
.rtbl tr:last-child td{border:none}
.rtbl tr:hover td{background:rgba(255,255,255,.02)}
.rnk{font-family:monospace;font-weight:800;color:var(--blue);width:16px;font-size:14px}
.rname{font-weight:700;font-size:12px}
.rcnt{font-size:10px;color:var(--muted)}
.rmono{font-family:monospace;font-size:12px}
.sbar{display:inline-block;width:72px;height:5px;background:var(--border);
      border-radius:3px;vertical-align:middle;overflow:hidden}
.sfill{height:100%;border-radius:3px}
.medal{font-size:14px}
.yield-chip{font-family:monospace;font-size:11px;font-weight:700;
            padding:2px 8px;border-radius:4px;border:1px solid}
.yc-hi{color:#3FB950;border-color:rgba(63,185,80,.4);background:rgba(63,185,80,.08)}
.yc-md{color:#D29922;border-color:rgba(210,153,34,.4);background:rgba(210,153,34,.08)}
.yc-lo{color:#8B949E;border-color:rgba(139,148,158,.3);background:rgba(139,148,158,.06)}

/* ── LEGEND ── */
.legend{display:flex;flex-wrap:wrap;gap:10px;margin-top:8px}
.li{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted)}
.ld{width:8px;height:8px;border-radius:50%}

/* ── DAX PANEL ── */
.dax-chip{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted);
          background:var(--panel);border:1px solid var(--border);border-radius:6px;
          padding:4px 10px;cursor:pointer;white-space:nowrap;font-family:monospace}
.dax-chip:hover{color:var(--text)}
.dax-row{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}

/* ── STATUS DOT ── */
.dot{width:6px;height:6px;border-radius:50%;display:inline-block;margin-right:4px}

@media(max-width:900px){.kpis{grid-template-columns:repeat(2,1fr)}.g2,.g3,.g23,.g32{grid-template-columns:1fr}}
</style>
</head>
<body>
<div id="app">

<!-- HEADER -->
<div class="hdr">
  <div class="logo">
    <div class="logo-icon">🏛</div>
    <div>
      <h1>European Real Estate — Market Intelligence</h1>
      <p>5,000 LISTINGS · 10 COUNTRIES · 10 CITIES · 7 PROPERTY TYPES · REAL DATASET</p>
    </div>
  </div>
  <div class="hdr-badges">
    <span class="hbadge hb-b">Price Analytics</span>
    <span class="hbadge hb-g">Investment Intelligence</span>
    <span class="hbadge hb-gr">Market Liquidity</span>
  </div>
</div>

<!-- FILTERS -->
<div class="filters">
  <div class="fg"><span class="flbl">Listing Type</span>
    <select id="f-lt"><option value="all">Sale + Rental</option><option value="0">For Sale</option><option value="1">For Rent</option></select>
  </div>
  <div class="fg"><span class="flbl">Country</span>
    <select id="f-ct"><option value="-1">All Countries</option></select>
  </div>
  <div class="fg"><span class="flbl">Property Type</span>
    <select id="f-tp"><option value="-1">All Types</option></select>
  </div>
  <div class="fg"><span class="flbl">City</span>
    <select id="f-ci"><option value="-1">All Cities</option></select>
  </div>
  <div class="fg"><span class="flbl">Min Bedrooms</span>
    <select id="f-bd">
      <option value="0">Any</option><option value="1">1+</option>
      <option value="2">2+</option><option value="3">3+</option><option value="4">4+</option>
    </select>
  </div>
  <div class="fg"><span class="flbl">Max Price / m²</span>
    <input type="range" id="f-sqm" min="42" max="19756" step="50" value="19756">
    <div class="fval" id="fv-sqm">≤ €19,756</div>
  </div>
  <div class="fg"><span class="flbl">Min Built Year</span>
    <input type="range" id="f-yr" min="1901" max="2021" step="1" value="1901">
    <div class="fval" id="fv-yr">All eras</div>
  </div>
  <button class="freset" id="f-reset">↺ Reset</button>
</div>

<!-- KPIs -->
<div class="kpis">
  <div class="kpi"><div class="kpi-stripe" style="background:var(--blue)"></div>
    <div class="kpi-lbl">Total Listings</div>
    <div class="kpi-val" id="k-n">—</div>
    <div class="kpi-sub">Active properties</div>
    <div class="kpi-delta kpi-up" id="k-ns">—</div>
  </div>
  <div class="kpi"><div class="kpi-stripe" style="background:var(--green)"></div>
    <div class="kpi-lbl">Avg Sale Price</div>
    <div class="kpi-val" id="k-price">—</div>
    <div class="kpi-sub">Mean asking (sale)</div>
    <div class="kpi-delta kpi-up" id="k-prices">—</div>
  </div>
  <div class="kpi"><div class="kpi-stripe" style="background:var(--gold)"></div>
    <div class="kpi-lbl">Avg Price / m²</div>
    <div class="kpi-val" id="k-sqm">—</div>
    <div class="kpi-sub">Market price density</div>
    <div class="kpi-delta kpi-up" id="k-sqms">—</div>
  </div>
  <div class="kpi"><div class="kpi-stripe" style="background:var(--red)"></div>
    <div class="kpi-lbl">Avg Days on Market</div>
    <div class="kpi-val" id="k-dom">—</div>
    <div class="kpi-sub">Liquidity signal</div>
    <div class="kpi-delta kpi-dn" id="k-doms">—</div>
  </div>
  <div class="kpi"><div class="kpi-stripe" style="background:var(--purple)"></div>
    <div class="kpi-lbl">Avg Gross Yield</div>
    <div class="kpi-val" id="k-yield">—</div>
    <div class="kpi-sub">Ann. rent ÷ last sold</div>
    <div class="kpi-delta kpi-up" id="k-yields">—</div>
  </div>
</div>

<!-- ROW 1: Bar + Combo -->
<div class="g2">
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Price per m² by Country</div>
           <div class="card-sub">Avg €/m² · sorted descending · real data</div></div>
      <span class="ctag ctag-b">Market Tier</span>
    </div>
    <div class="cw" style="height:220px"><canvas id="c-country"></canvas></div>
  </div>
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Property Type: Volume vs Value</div>
           <div class="card-sub">Listing count (bars) vs avg €/m² (line) per type</div></div>
      <span class="ctag ctag-g">Type Analysis</span>
    </div>
    <div class="cw" style="height:220px"><canvas id="c-type"></canvas></div>
  </div>
</div>

<!-- ROW 2: Matrix + Amenity -->
<div class="g2">
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Investor Opportunity Matrix</div>
           <div class="card-sub">€/m² vs days on market · bubble = gross yield %</div></div>
      <span class="ctag ctag-gr">Strategic Quadrant</span>
    </div>
    <div class="cw" style="height:220px"><canvas id="c-matrix"></canvas></div>
    <div class="insight" id="ins-matrix">Loading…</div>
  </div>
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Amenity & Feature Price Premium</div>
           <div class="card-sub">% price lift vs listings without feature · measured on real data</div></div>
      <span class="ctag ctag-p">Value Drivers</span>
    </div>
    <div class="cw" style="height:220px"><canvas id="c-amenity"></canvas></div>
    <div class="insight" id="ins-amenity">Loading…</div>
  </div>
</div>

<!-- ROW 3: City ranking table + Distribution -->
<div class="g23">
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">City Investment Ranking</div>
           <div class="card-sub">Composite: value weight + liquidity + gross yield</div></div>
      <span class="ctag ctag-gr">Ranked</span>
    </div>
    <div id="city-table"></div>
  </div>
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Price Distribution</div>
           <div class="card-sub">Listing count across sale price bands</div></div>
      <span class="ctag ctag-b">Distribution</span>
    </div>
    <div class="cw" style="height:200px"><canvas id="c-dist"></canvas></div>
    <div class="insight" id="ins-dist">Loading…</div>
  </div>
</div>

<!-- ROW 4: Energy + Size + Decade -->
<div class="g3">
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Energy Rating vs Price</div>
           <div class="card-sub">Avg €/m² by EPC label A→G</div></div>
      <span class="ctag ctag-gr">EPC Impact</span>
    </div>
    <div class="cw" style="height:180px"><canvas id="c-energy"></canvas></div>
  </div>
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Size Band Price Density</div>
           <div class="card-sub">Economies of scale effect on €/m²</div></div>
      <span class="ctag ctag-p">Size Effect</span>
    </div>
    <div class="cw" style="height:180px"><canvas id="c-size"></canvas></div>
  </div>
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Build Decade vs Price</div>
           <div class="card-sub">Avg €/m² by construction era</div></div>
      <span class="ctag ctag-g">Vintage Premium</span>
    </div>
    <div class="cw" style="height:180px"><canvas id="c-decade"></canvas></div>
  </div>
</div>

<!-- ROW 5: DOM + Parking -->
<div class="g2">
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Days on Market by City</div>
           <div class="card-sub">Green &lt;150d · Amber 150–175d · Red &gt;175d</div></div>
      <span class="ctag ctag-r">Liquidity</span>
    </div>
    <div class="cw" style="height:220px"><canvas id="c-dom"></canvas></div>
  </div>
  <div class="card">
    <div class="card-hdr">
      <div><div class="card-title">Parking Spots vs Price Density</div>
           <div class="card-sub">Avg €/m² by parking count band</div></div>
      <span class="ctag ctag-g">Parking Value</span>
    </div>
    <div class="cw" style="height:220px"><canvas id="c-park"></canvas></div>
    <div class="insight" id="ins-park">Loading…</div>
  </div>
</div>

<!-- FOOTER -->
