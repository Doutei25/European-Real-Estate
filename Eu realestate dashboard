// ══════ KPIs ══════
function kpis(d){
  const n=d.length;
  document.getElementById('k-n').textContent=n.toLocaleString();
  document.getElementById('k-ns').textContent=((n/5000)*100).toFixed(1)+'% of dataset';
  const sale=d.filter(r=>r[2]===0&&r[7]>0);
  const rent=d.filter(r=>r[2]===1&&r[8]>0&&r[11]>0);
  const ap=sale.length?avg(sale.map(r=>r[7])):0;
  document.getElementById('k-price').textContent=ap?fmtE(ap):'—';
  document.getElementById('k-prices').textContent=sale.length+' sale listings';
  const psqm=d.filter(r=>r[9]>0);
  const asqm=psqm.length?avg(psqm.map(r=>r[9])):0;
  document.getElementById('k-sqm').textContent=asqm?'€'+Math.round(asqm).toLocaleString():'—';
  document.getElementById('k-sqms').textContent=psqm.length+' with sqm data';
  const dom=d.filter(r=>r[10]>0);
  const adom=dom.length?avg(dom.map(r=>r[10])):0;
  document.getElementById('k-dom').textContent=adom?Math.round(adom)+'d':'—';
  document.getElementById('k-doms').textContent='avg days to sell';
  const yld=rent.filter(r=>r[11]>0);
  const ay=yld.length?avg(yld.map(r=>r[8]*12/r[11]*100)):0;
  document.getElementById('k-yield').textContent=ay?ay.toFixed(2)+'%':'—';
  document.getElementById('k-yields').textContent='gross rental yield';
}

