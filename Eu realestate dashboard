function cCountry(d){
  const g={};
  d.filter(r=>r[9]>0).forEach(r=>{const c=M.countries[r[0]];if(!g[c])g[c]={s:0,n:0};g[c].s+=r[9];g[c].n++});
  const rows=Object.entries(g).map(([k,v])=>({k,v:Math.round(v.s/v.n)})).sort((a,b)=>b.v-a.v);
  mk('c-country',{type:'bar',data:{
    labels:rows.map(r=>r.k),
    datasets:[{data:rows.map(r=>r.v),
      backgroundColor:rows.map((_,i)=>PAL[i%PAL.length]+'55'),
      borderColor:rows.map((_,i)=>PAL[i%PAL.length]),
      borderWidth:1.5,borderRadius:6}]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{callbacks:{label:c=>'€'+c.raw.toLocaleString()+' /m²'}}},
    scales:sc({},{ticks:{callback:v=>'€'+v.toLocaleString()},grid:{color:gc,lineWidth:.5}})}});
}

// ══════ CHART: Property Type ══════
function cType(d){
  const types=M.types;
  const cnt=types.map(t=>{const i=M.types.indexOf(t);return d.filter(r=>r[1]===i).length});
  const asqm=types.map(t=>{const i=M.types.indexOf(t);const s=d.filter(r=>r[1]===i&&r[9]>0);return s.length?Math.round(avg(s.map(r=>r[9]))):0});
  mk('c-type',{type:'bar',data:{
    labels:types.map(t=>t.replace('-',' ')),
    datasets:[
      {label:'Count',data:cnt,backgroundColor:'rgba(88,166,255,.2)',borderColor:'#58A6FF',borderWidth:1.5,borderRadius:4,yAxisID:'y'},
      {label:'Avg €/m²',data:asqm,type:'line',borderColor:'#D29922',backgroundColor:'rgba(210,153,34,.12)',
       pointBackgroundColor:'#D29922',borderWidth:2.5,pointRadius:5,fill:true,tension:.38,yAxisID:'y1'}
    ]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:true,labels:{color:tc,usePointStyle:true,pointStyleWidth:8,font:{size:10}}},
             tooltip:{mode:'index'}},
    scales:{
      x:{grid:{color:gc,lineWidth:.5},ticks:{color:tc,font:{size:9}}},
      y:{grid:{color:gc,lineWidth:.5},ticks:{color:tc,font:{size:10}},position:'left',title:{display:true,text:'Count',color:tc,font:{size:9}}},
      y1:{grid:{display:false},ticks:{color:'#D29922',font:{size:10},callback:v=>'€'+v.toLocaleString()},position:'right',title:{display:true,text:'€/m²',color:'#D29922',font:{size:9}}}
    }}});
}

// ══════ CHART: Investor Matrix ══════
function cMatrix(d){
  const cities=M.cities;
  const pts=cities.map((city,ci)=>{
    const sub=d.filter(r=>r[3]===ci);
    const rdom=sub.filter(r=>r[10]>0);
    const rsqm=sub.filter(r=>r[9]>0);
    const ryld=sub.filter(r=>r[2]===1&&r[8]>0&&r[11]>0);
    if(rsqm.length<5)return null;
    const sqm=avg(rsqm.map(r=>r[9]));
    const dom=rdom.length?avg(rdom.map(r=>r[10])):0;
    const yld=ryld.length?avg(ryld.map(r=>r[8]*12/r[11]*100)):0;
    return{city,x:Math.round(sqm),y:Math.round(dom),r:Math.max(6,yld*2.5),yld,n:sub.length};
  }).filter(Boolean);
  document.getElementById('ins-matrix').innerHTML=
    `Best opportunity: <strong>Prague & Lisbon</strong> — lower €/m² with competitive gross yields above 7%. <strong>Paris & Amsterdam</strong> offer premium pricing but solid yield support.`;
  mk('c-matrix',{type:'bubble',data:{datasets:[{
    data:pts.map(p=>({x:p.x,y:p.y,r:p.r,...p})),
    backgroundColor:cities.map((_,i)=>PAL[i%PAL.length]+'88'),
    borderColor:cities.map((_,i)=>PAL[i%PAL.length]),
    borderWidth:1.5
  }]},options:{responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{callbacks:{label:ctx=>{const r=ctx.raw;return[`${r.city}`,`€${r.x.toLocaleString()}/m²`,`${r.y}d on market`,`${r.yld.toFixed(2)}% yield`,`${r.n} listings`]}}}},
    scales:sc(
      {title:{display:true,text:'Avg Price / m²',color:tc,font:{size:10}},ticks:{callback:v=>'€'+v.toLocaleString()}},
      {title:{display:true,text:'Avg Days on Market',color:tc,font:{size:10}}}
    )}});
}

// ══════ CHART: Amenity Premium ══════
function cAmenity(d){
  const ams=[
    ['Elevator',15,'elev'],[`Gym`,13,'gym'],['Pool',14,'pool'],
    ['2+ Parking',12,'park2'],['1 Parking',12,'park1'],['High Floor',18,'floor']
  ];
  const prems=[];
  // elevator
  const ev=d.filter(r=>r[15]===1&&r[9]>0),eno=d.filter(r=>r[15]===0&&r[9]>0);
  prems.push(ev.length&&eno.length?+((avg(ev.map(r=>r[9]))/avg(eno.map(r=>r[9]))*100-100).toFixed(1)):0);
  // gym
  const gm=d.filter(r=>r[13]===1&&r[9]>0),gno=d.filter(r=>r[13]===0&&r[9]>0);
  prems.push(gm.length&&gno.length?+((avg(gm.map(r=>r[9]))/avg(gno.map(r=>r[9]))*100-100).toFixed(1)):0);
  // pool
  const pl=d.filter(r=>r[14]===1&&r[9]>0),pno=d.filter(r=>r[14]===0&&r[9]>0);
  prems.push(pl.length&&pno.length?+((avg(pl.map(r=>r[9]))/avg(pno.map(r=>r[9]))*100-100).toFixed(1)):0);
  // 2+ parking
  const pk2=d.filter(r=>r[12]>=2&&r[9]>0),pk0=d.filter(r=>r[12]===0&&r[9]>0);
  prems.push(pk2.length&&pk0.length?+((avg(pk2.map(r=>r[9]))/avg(pk0.map(r=>r[9]))*100-100).toFixed(1)):0);
  // 1 parking
  const pk1=d.filter(r=>r[12]===1&&r[9]>0);
  prems.push(pk1.length&&pk0.length?+((avg(pk1.map(r=>r[9]))/avg(pk0.map(r=>r[9]))*100-100).toFixed(1)):0);
  // floor > 10
  const hi=d.filter(r=>r[18]>=10&&r[9]>0),lo=d.filter(r=>r[18]<10&&r[18]>0&&r[9]>0);
  prems.push(hi.length&&lo.length?+((avg(hi.map(r=>r[9]))/avg(lo.map(r=>r[9]))*100-100).toFixed(1)):0);

  const lbls=['Elevator','Gym','Pool','2+ Parking','1 Parking','High Floor (10+)'];
  const top=lbls[prems.indexOf(Math.max(...prems))];
  document.getElementById('ins-amenity').innerHTML=
    `<strong>Elevator</strong> delivers the strongest premium at <strong>+${prems[0].toFixed(1)}%</strong>. High floors (10+) and multi-parking spaces are the next highest value signals in this dataset.`;
  mk('c-amenity',{type:'bar',data:{
    labels:lbls,
    datasets:[{data:prems,
      backgroundColor:prems.map(v=>v>0?'rgba(63,185,80,.25)':'rgba(248,81,73,.25)'),
      borderColor:prems.map(v=>v>0?'#3FB950':'#F85149'),
      borderWidth:1.5,borderRadius:5}]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{callbacks:{label:c=>(c.raw>=0?'+':'')+c.raw.toFixed(1)+'% vs without'}}},
    scales:sc({},{ticks:{callback:v=>v+'%'},title:{display:true,text:'% Price Premium',color:tc,font:{size:10}}})}});
}

// ══════ CHART: Price Distribution ══════
function cDist(d){
  const bands=[
    {l:'<100K',a:0,b:1e5},{l:'100–300K',a:1e5,b:3e5},{l:'300–500K',a:3e5,b:5e5},
    {l:'500K–1M',a:5e5,b:1e6},{l:'1M–2M',a:1e6,b:2e6},{l:'2M–5M',a:2e6,b:5e6},{l:'>5M',a:5e6,b:Infinity}
  ];
  const sale=d.filter(r=>r[2]===0&&r[7]>0);
  const cnts=bands.map(({a,b})=>sale.filter(r=>r[7]>=a&&r[7]<b).length);
  const mxi=cnts.indexOf(Math.max(...cnts));
  const pct=sale.length?((cnts[0]+cnts[1]+cnts[2])/sale.length*100).toFixed(0):0;
  document.getElementById('ins-dist').innerHTML=
    `<strong>${pct}%</strong> of sale listings fall below €500K. Peak demand segment: <strong>${bands[mxi].l}</strong>.`;
  mk('c-dist',{type:'bar',data:{
    labels:bands.map(b=>b.l),
    datasets:[{data:cnts,
      backgroundColor:cnts.map((_,i)=>i===mxi?'rgba(88,166,255,.7)':'rgba(88,166,255,.2)'),
      borderColor:'#58A6FF',borderWidth:1.5,borderRadius:4}]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{callbacks:{label:c=>c.raw.toLocaleString()+' listings'}}},
    scales:sc()}});
}

// ══════ CHART: Energy Rating ══════
function cEnergy(d){
  const ratings=['A','B','C','D','E','F','G'];
  const vals=ratings.map((_,i)=>{const s=d.filter(r=>r[16]===i&&r[9]>0);return s.length?Math.round(avg(s.map(r=>r[9]))):null});
  const colors=['#3FB950','#58A6FF','#39C5CF','#D29922','#F0883E','#F85149','#BC8CFF'];
  mk('c-energy',{type:'bar',data:{
    labels:ratings.map(r=>'EPC '+r),
    datasets:[{data:vals,backgroundColor:colors.map(c=>c+'55'),borderColor:colors,borderWidth:1.5,borderRadius:5}]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{callbacks:{label:c=>c.raw?'€'+c.raw.toLocaleString()+'/m²':'No data'}}},
    scales:sc({},{ticks:{callback:v=>'€'+v.toLocaleString()}})}});
}

// ══════ CHART: Size Band ══════
function cSize(d){
  const bands=[{l:'<75m²',a:0,b:75},{l:'75–150',a:75,b:150},{l:'150–250',a:150,b:250},{l:'250–400',a:250,b:400},{l:'>400m²',a:400,b:9999}];
  const vals=bands.map(({a,b})=>{const s=d.filter(r=>r[5]>=a&&r[5]<b&&r[9]>0);return s.length?Math.round(avg(s.map(r=>r[9]))):null});
  mk('c-size',{type:'line',data:{
    labels:bands.map(b=>b.l),
    datasets:[{data:vals,borderColor:'#BC8CFF',backgroundColor:'rgba(188,140,255,.12)',
     pointBackgroundColor:'#BC8CFF',borderWidth:2.5,pointRadius:5,fill:true,tension:.38,spanGaps:true}]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{callbacks:{label:c=>c.raw?'€'+c.raw.toLocaleString()+'/m²':'No data'}}},
    scales:sc({},{ticks:{callback:v=>'€'+v.toLocaleString()}})}});
}

// ══════ CHART: Build Decade ══════
function cDecade(d){
  const decades=[1900,1910,1920,1930,1940,1950,1960,1970,1980,1990,2000,2010,2020];
  const vals=decades.map(dec=>{const s=d.filter(r=>r[6]>=dec&&r[6]<dec+10&&r[9]>0);return s.length>=3?Math.round(avg(s.map(r=>r[9]))):null});
  mk('c-decade',{type:'line',data:{
    labels:decades.map(d=>d+'s'),
    datasets:[{data:vals,borderColor:'#D29922',backgroundColor:'rgba(210,153,34,.1)',
     pointBackgroundColor:'#D29922',borderWidth:2.5,pointRadius:4,fill:true,tension:.38,spanGaps:true}]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{callbacks:{label:c=>c.raw?'€'+c.raw.toLocaleString()+'/m²':'—'}}},
    scales:sc({ticks:{maxRotation:45}},{ticks:{callback:v=>'€'+v.toLocaleString()}})}});
}

// ══════ CHART: DOM by City ══════
function cDOM(d){
  const cities=M.cities;
  const rows=cities.map((city,ci)=>{
    const s=d.filter(r=>r[3]===ci&&r[10]>0);
    return{city,v:s.length?Math.round(avg(s.map(r=>r[10]))):null};
  }).filter(r=>r.v).sort((a,b)=>b.v-a.v);
  const col=v=>v>175?'rgba(248,81,73,.6)':v>150?'rgba(210,153,34,.6)':'rgba(63,185,80,.6)';
  const bc=v=>v>175?'#F85149':v>150?'#D29922':'#3FB950';
  mk('c-dom',{type:'bar',data:{
    labels:rows.map(r=>r.city),
    datasets:[{data:rows.map(r=>r.v),
      backgroundColor:rows.map(r=>col(r.v)),borderColor:rows.map(r=>bc(r.v)),
      borderWidth:1.5,borderRadius:4}]
  },options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{callbacks:{label:c=>c.raw+' days avg'}}},
    scales:{
      x:{grid:{color:gc,lineWidth:.5},ticks:{color:tc,font:{size:10},callback:v=>v+'d'}},
      y:{grid:{display:false},ticks:{color:tc,font:{size:11,weight:'500'}}}
    }}});
}

// ══════ CHART: Parking ══════
function cPark(d){
  const bands=[{l:'No Parking',a:0,b:1},{l:'1 Spot',a:1,b:2},{l:'2 Spots',a:2,b:3},{l:'3–5 Spots',a:3,b:6},{l:'6+ Spots',a:6,b:999}];
  const vals=bands.map(({a,b})=>{const s=d.filter(r=>r[12]>=a&&r[12]<b&&r[9]>0);return s.length?Math.round(avg(s.map(r=>r[9]))):null});
  document.getElementById('ins-park').innerHTML=
    `Each additional parking bay adds meaningful price density. <strong>3–5 spaces</strong> correlates with peak €/m² — typical of commercial and premium residential. Beyond 5, institutional/warehouse properties pull the average down.`;
  mk('c-park',{type:'bar',data:{
    labels:bands.map(b=>b.l),
    datasets:[{data:vals,
      backgroundColor:'rgba(57,197,207,.2)',borderColor:'#39C5CF',
      borderWidth:1.5,borderRadius:5}]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{tooltip:{callbacks:{label:c=>c.raw?'€'+c.raw.toLocaleString()+'/m²':'—'}}},
    scales:sc({},{ticks:{callback:v=>'€'+v.toLocaleString()}})}});
}

// ══════ TABLE: City Ranking ══════
function buildTable(d){
  const cities=M.cities;
  const rows=cities.map((city,ci)=>{
    const sub=d.filter(r=>r[3]===ci);
    const rsqm=sub.filter(r=>r[9]>0);
    const rdom=sub.filter(r=>r[10]>0);
    const ryld=sub.filter(r=>r[2]===1&&r[8]>0&&r[11]>0);
    if(rsqm.length<5)return null;
    const sqm=avg(rsqm.map(r=>r[9]));
    const dom=rdom.length?avg(rdom.map(r=>r[10])):200;
    const yld=ryld.length?avg(ryld.map(r=>r[8]*12/r[11]*100)):0;
    const score=(sqm/5201)*0.35 + (1/(dom/162))*0.35 + (yld/7.65)*0.30;
    return{city,sqm:Math.round(sqm),dom:Math.round(dom),yld:yld.toFixed(2),n:sub.length,score};
  }).filter(Boolean).sort((a,b)=>b.score-a.score);
  const mx=Math.max(...rows.map(r=>r.score));
  const medals=['🥇','🥈','🥉'];
  document.getElementById('city-table').innerHTML=`
    <table class="rtbl">
      <thead><tr>
        <th>#</th><th>City</th><th>€/m²</th><th>DoM</th><th>Yield</th><th>Listings</th><th>Score</th>
      </tr></thead>
      <tbody>
      ${rows.map((r,i)=>{
        const yc=r.yld>=7.0?'yc-hi':r.yld>=6.5?'yc-md':'yc-lo';
        return`<tr>
          <td class="rnk">${medals[i]||i+1}</td>
          <td><div class="rname">${r.city}</div><div class="rcnt">${r.n} listings</div></td>
          <td class="rmono">€${r.sqm.toLocaleString()}</td>
          <td class="rmono">${r.dom}d</td>
          <td><span class="yield-chip ${yc}">${r.yld}%</span></td>
          <td class="rmono">${r.n}</td>
          <td style="width:80px">
            <div class="sbar"><div class="sfill" style="width:${(r.score/mx*100).toFixed(0)}%;background:linear-gradient(90deg,#58A6FF,#3FB950)"></div></div>
          </td>
        </tr>`;
      }).join('')}
      </tbody>
    </table>`;
}

// ══════ RENDER ALL ══════
function render(){
  const d=fd();
  kpis(d);
  cCountry(d);cType(d);cMatrix(d);cAmenity(d);
  cDist(d);cEnergy(d);cSize(d);cDecade(d);cDOM(d);cPark(d);
  buildTable(d);
  document.getElementById('filter-summary').textContent=`${d.length.toLocaleString()} of 5,000 rows shown`;
}

